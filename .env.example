# ── Twilio (telephony) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15551234567

# ── Public endpoint (domain pointed at the VM, for Twilio webhooks) ───
# e.g. voice.yourcompany.com — must resolve to the VM's public IP
PUBLIC_DOMAIN=voice.yourcompany.com
PUBLIC_SCHEME=https

# ── Models (V100 16GB: use AWQ quantized 7B) ───────────────────────────
WHISPER_MODEL_SIZE=distil-large-v3
LLM_MODEL=hugging-quants/Meta-Llama-3.1-8B-Instruct-AWQ-INT4
HF_TOKEN=

# ── TTS (choose engine: piper or kokoro) ───────────────────────────────
TTS_ENGINE=piper
PIPER_VOICE=en_US-lessac-medium
PIPER_SAMPLE_RATE=22050
KOKORO_VOICE=af_bella
